APP_NAME=ACARA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
ASSET_URL=
URL_PICTURE=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_CHANNEL=stack
